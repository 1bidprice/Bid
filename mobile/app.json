{
  "expo": {
    "name": "Investor Control",
    "slug": "investor-control",
    "version": "0.4.2",
    "icon": "./assets/investor-control-icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "plugins": [
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#0B66FF",
          "defaultChannel": "price-alerts"
        }
      ],
      "expo-document-picker"
    ],
    "android": {
      "package": "gr.investorcontrol.app",
      "versionCode": 5,
      "allowBackup": false,
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/investor-control-icon.png",
        "backgroundColor": "#07163E"
      }
    },
    "ios": {
      "bundleIdentifier": "gr.investorcontrol.app",
      "buildNumber": "5",
      "supportsTablet": false
    }
  }
}
